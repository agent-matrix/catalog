            "name": "--user",
            "type": "named",
            "value": "65532:65532"
          },
          {
            "description": "Writable ephemeral workspace (rootfs is read-only).",
            "name": "--tmpfs",
            "type": "named",
            "value": "/tmp:rw,noexec,nosuid,size=64m"
          },
          {
            "description": "Memory limit.",
