            "value": "none"
          },
          {
            "description": "Read-only root filesystem.",
            "name": "--read-only",
            "type": "named"
          },
          {
            "description": "Drop all Linux capabilities.",
            "name": "--cap-drop",
            "type": "named",
            "value": "ALL"
          },
          {
