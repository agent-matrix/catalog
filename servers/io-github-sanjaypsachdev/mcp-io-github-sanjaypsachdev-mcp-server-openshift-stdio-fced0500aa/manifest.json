  "mcp_registration": {
    "server": {
      "exec": {
        "cmd": [
          "podman",
          {
            "description": "Keep stdin open for stdio MCP transport",
            "name": "-i",
            "type": "named"
          },
          {
            "description": "Mount host kubeconfig so oc can reach the cluster",
            "name": "-v",
            "type": "named",
            "value": "{kube_config}:/home/nodejs/.kube:ro",
            "variables": {
              "kube_config": {
                "default": "~/.kube/config",
                "description": "Path to kubeconfig on host",
                "format": "filepath"
              }
            }
          },
          "docker.io/sanjaypsachdev/mcp-server-openshift:1.2.0"
        ],
        "env": {}
      },
      "transport": "STDIO"
    }
  },
